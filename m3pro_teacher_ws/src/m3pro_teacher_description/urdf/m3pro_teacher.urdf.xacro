<?xml version="1.0"?>
<robot name="m3pro_teacher" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <material name="body_green">
    <color rgba="0.0 0.45 0.32 1.0"/>
  </material>
  <material name="dark_gray">
    <color rgba="0.08 0.09 0.09 1.0"/>
  </material>
  <material name="sensor_cyan">
    <color rgba="0.0 0.7 0.8 1.0"/>
  </material>
  <material name="arm_silver">
    <color rgba="0.72 0.76 0.78 1.0"/>
  </material>
  <material name="warning_red">
    <color rgba="0.8 0.08 0.06 1.0"/>
  </material>

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.055" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry>
        <box size="0.34 0.28 0.07"/>
      </geometry>
      <material name="body_green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry>
        <box size="0.34 0.28 0.07"/>
      </geometry>
    </collision>
  </link>

  <xacro:macro name="wheel" params="name y">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="${pi / 2} 0 0"/>
        <geometry>
          <cylinder radius="0.045" length="0.035"/>
        </geometry>
        <material name="dark_gray"/>
      </visual>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="0 ${y} 0.0" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel name="left_wheel" y="0.155"/>
  <xacro:wheel name="right_wheel" y="-0.155"/>

  <link name="scan0_frame">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.025"/>
      </geometry>
      <material name="sensor_cyan"/>
    </visual>
  </link>
  <joint name="scan0_joint" type="fixed">
    <parent link="base_link"/>
    <child link="scan0_frame"/>
    <origin xyz="0.17 0 0.11" rpy="0 0 0"/>
  </joint>

  <link name="scan1_frame">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.025"/>
      </geometry>
      <material name="sensor_cyan"/>
    </visual>
  </link>
  <joint name="scan1_joint" type="fixed">
    <parent link="base_link"/>
    <child link="scan1_frame"/>
    <origin xyz="-0.17 0 0.11" rpy="0 0 ${pi}"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.065 0.028 0.038"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.18 0 0.23" rpy="0 0 0"/>
  </joint>

  <link name="camera_color_optical_frame"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_color_optical_frame"/>
    <origin xyz="0.025 0 0" rpy="${-pi / 2} 0 ${-pi / 2}"/>
  </joint>

  <link name="arm_base_link">
    <visual>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.055" length="0.07"/>
      </geometry>
      <material name="arm_silver"/>
    </visual>
  </link>
  <joint name="arm_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base_link"/>
    <origin xyz="0.02 0 0.105" rpy="0 0 0"/>
  </joint>

  <link name="shoulder_pan_link">
    <visual>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.045" length="0.07"/>
      </geometry>
      <material name="arm_silver"/>
    </visual>
  </link>
  <joint name="base_yaw_joint" type="revolute">
    <parent link="arm_base_link"/>
    <child link="shoulder_pan_link"/>
    <origin xyz="0 0 0.07" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="4.0" velocity="1.0"/>
  </joint>

  <link name="upper_arm_link">
    <visual>
      <origin xyz="0.055 0 0" rpy="0 ${pi / 2} 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.11"/>
      </geometry>
      <material name="arm_silver"/>
    </visual>
  </link>
  <joint name="shoulder_joint" type="revolute">
    <parent link="shoulder_pan_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 0.065" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="4.0" velocity="1.0"/>
  </joint>

  <link name="forearm_link">
    <visual>
      <origin xyz="0.055 0 0" rpy="0 ${pi / 2} 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.11"/>
      </geometry>
      <material name="arm_silver"/>
    </visual>
  </link>
  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0.11 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="4.0" velocity="1.0"/>
  </joint>

  <link name="wrist_pitch_link">
    <visual>
      <origin xyz="0.035 0 0" rpy="0 ${pi / 2} 0"/>
      <geometry>
        <cylinder radius="0.016" length="0.07"/>
      </geometry>
      <material name="arm_silver"/>
    </visual>
  </link>
  <joint name="wrist_pitch_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_pitch_link"/>
    <origin xyz="0.11 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="4.0" velocity="1.0"/>
  </joint>

  <link name="wrist_roll_link">
    <visual>
      <origin xyz="0.025 0 0" rpy="0 ${pi / 2} 0"/>
      <geometry>
        <cylinder radius="0.014" length="0.05"/>
      </geometry>
      <material name="warning_red"/>
    </visual>
  </link>
  <joint name="wrist_roll_joint" type="revolute">
    <parent link="wrist_pitch_link"/>
    <child link="wrist_roll_link"/>
    <origin xyz="0.07 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.57" upper="1.57" effort="2.0" velocity="1.0"/>
  </joint>

  <link name="gripper_palm_link">
    <visual>
      <origin xyz="0.02 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.055 0.025"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
  </link>
  <joint name="gripper_palm_joint" type="fixed">
    <parent link="wrist_roll_link"/>
    <child link="gripper_palm_link"/>
    <origin xyz="0.05 0 0" rpy="0 0 0"/>
  </joint>

  <link name="left_finger_link">
    <visual>
      <origin xyz="0.035 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.07 0.012 0.018"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
  </link>
  <joint name="left_finger_joint" type="prismatic">
    <parent link="gripper_palm_link"/>
    <child link="left_finger_link"/>
    <origin xyz="0.035 0.018 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.04" effort="1.0" velocity="0.1"/>
  </joint>

  <link name="right_finger_link">
    <visual>
      <origin xyz="0.035 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.07 0.012 0.018"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
  </link>
  <joint name="right_finger_joint" type="prismatic">
    <parent link="gripper_palm_link"/>
    <child link="right_finger_link"/>
    <origin xyz="0.035 -0.018 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="0.04" effort="1.0" velocity="0.1"/>
  </joint>
</robot>
